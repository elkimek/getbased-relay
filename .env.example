# getbased-relay configuration
# Copy to .env and adjust as needed

# Ports
RELAY_PORT=4000            # Evolu WebSocket relay
ADMIN_PORT=4001            # Health/metrics HTTP server

# Storage
RELAY_NAME=evolu-relay     # SQLite DB filename (without .db)
DATA_DIR=./data            # Directory for DB and metadata files

# Quotas
QUOTA_PER_OWNER_MB=10      # Max stored bytes per identity (MB)
QUOTA_GLOBAL_MB=1000       # Max total stored bytes across all owners (MB)

# Owner lifecycle
OWNER_TTL_DAYS=90          # Days of inactivity before owner flagged as stale

# Logging
LOG_LEVEL=info             # debug, info, warn, error
LOG_FORMAT=json            # json (for log aggregation) or text (for dev)
ENABLE_EVOLU_LOGGING=false # Evolu's raw CRDT/SQL logs (very verbose)

# Admin security
# ADMIN_TOKEN=your-secret  # Bearer token for /metrics endpoint (omit for open access)
